{
  "name": "tenchi-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run content && next dev",
    "content": "bun run scripts/build-search-index.ts && bun run scripts/build-llms-txt.ts",
    "build": "bun run content && next build --webpack",
    "start": "next start",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.2.10",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "github-slugger": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.3.0"
  }
}
