      "post": {
        "description": "Idempotency-Key is required. Retrying the same validated input with the same key returns the original task response; reusing a key for different input returns 409.",
        "operationId": "create_task",
        "parameters": [
          {
            "in": "header",
            "name": "idempotency-key",
            "required": true,
            "schema": {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "title": "Idempotency Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "project_id": {
                    "title": "Project Id",
                    "type": "string"
                  },
                  "title": {
                    "maxLength": 200,
                    "minLength": 1,
                    "title": "Title",
                    "type": "string"
                  }
                },
                "required": [
                  "project_id",
                  "title"
                ],
                "title": "CreateTask",
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "id": {
                      "title": "Id",
                      "type": "string"
                    },
                    "project_id": {
                      "title": "Project Id",
                      "type": "string"
                    },
                    "status": {
                      "$ref": "#/components/schemas/TaskStatus"
                    },
                    "title": {
                      "title": "Title",
                      "type": "string"
                    },
                    "version": {
                      "minimum": 1,
                      "title": "Version",
                      "type": "integer"
                    }
                  },
                  "required": [
                    "id",
                    "project_id",
                    "title",
                    "status",
                    "version"
                  ],
                  "title": "Task",
                  "type": "object"
                }
              }
            },
            "description": "Successful response",
            "headers": {
              "ETag": {
                "required": true,
                "schema": {
                  "pattern": "^\"[1-9][0-9]*\"$",
                  "title": "Etag",
                  "type": "string"
                }
              },
              "Location": {
                "required": true,
                "schema": {
                  "title": "Location",
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "UNAUTHORIZED: Unauthorized"
