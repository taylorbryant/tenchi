                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "REQUEST_TIMEOUT: Request deadline exceeded"
          }
        },
        "summary": "Create a task in one of the current user's projects",
        "tags": [
          "tasks"
        ],
        "x-timeout-seconds": 10.0
      }
