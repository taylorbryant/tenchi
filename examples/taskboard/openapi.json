      "patch": {
        "description": "Requires the strong ETag from the latest task response in If-Match. A missing precondition returns 428; a stale one returns 412.",
        "operationId": "update_task",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "title": "Task Id",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "if-match",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^\"[1-9][0-9]*\"$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "If Match"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "description": "Partial update: ``None`` fields are left unchanged.",
                "properties": {
                  "status": {
                    "anyOf": [
                      {
                        "$ref": "#/components/schemas/TaskStatus"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "title": {
                    "anyOf": [
